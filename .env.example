# Convex Configuration
# Get your Convex URL from https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-project.convex.cloud

# Ave OAuth Configuration (optional - for Ave authentication)
# Get your client ID from Ave developer portal
VITE_AVE_CLIENT_ID=app_your_client_id_here

# Optional: override connector page URL (defaults to https://aveid.net/connect)
VITE_AVE_CONNECT_URL=https://aveid.net/connect

# Connector server settings (set in Convex environment)
# Required for code exchange in connector callback
AVE_CLIENT_SECRET=your_ave_client_secret_here
# Iris Convex HTTP base URL (used for delegated inference)
IRIS_HTTP_URL=https://your-iris-deployment.convex.site

# Assistant sidebar uses Iris delegated inference.
# Ensure IRIS_HTTP_URL points at your Iris deployment and Ave connector is configured.
